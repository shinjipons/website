								</div>
							),
						)}
					</div>
				) : (
					<p>Nothing scheduled</p>
				)
			}
		</section> -->

		<!-- Blog Posts Section -->
		<section id="writing">
			<h1>Writing</h1>
			{
				blogPosts.length > 0 ? (
					<div>
						{blogPosts.map((post) => (
							<a href={`/writing/${post.id}`} class="blog-card">
								<p class="date-year">
									{post.data.pubDate.toLocaleDateString("en-US", {
										year: "numeric",
										// month: "long",
										// day: "2-digit",
									})}
								</p>
								<h3 class="title">{post.data.title}</h3>
								<p class="date-monthday">
									{post.data.pubDate.toLocaleDateString("en-US", {
										// year: "numeric",
										month: "long",
										day: "2-digit",
									})}
								</p>
							</a>
						))}
					</div>
				) : (
					<p>Check back soon...</p>
				)
			}
		</section>

		<!-- Work Projects Section -->
		<section id="projects">
			<h1>Projects</h1>
			{
				workProjects.length > 0 ? (
					<div class="cards-container">

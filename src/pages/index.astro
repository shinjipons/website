);
const galleryImages = Object.keys(galleryGlob)
	.map((path) => path.replace("/public", ""))
	.sort();

// Archive images — auto-scanned from public/media/archive/
const archiveGlob = import.meta.glob(
	"/public/media/archive/**/*.{jpg,jpeg,png,webp,gif,avif,JPG,JPEG,PNG,WEBP,GIF,AVIF}",
);
const archiveImages = Object.keys(archiveGlob)
	.map((path) => path.replace("/public", ""))
	.sort();
---

<BaseLayout title="Shinji Pons" description="Personal website">
	<div class="container">
		<!-- Header section -->
		<section id="introduction">
			<h1>Shinji Pons</h1>
			<h3>Updated on {lastUpdated}</h3>
		</section>
		<section>
			<p>I was born in Tokyo and now live in Budapest, Hungary.</p>
			<p>
				I'm a senior product designer at <a
					href="https://formlabs.com/"
					target="_blank">Formlabs</a
				>, where I work on software that makes professional-grade 3D printing
				more intuitive. Previously, I worked at Autodesk, LEGO, Shapr3D and
				Electronic Arts.
			</p>
			<p>
				I care about the full picture: how something looks, how it works, how it
				feels on the first use and the thousandth. I'm drawn to complexity that
				rewards patience: hardware-adjacent flows, emerging workflows, and the
				small details that separate good from exceptional.
			</p>
			<p>My approach is simple: do less, but better than everyone else.</p>
			<p>
				You can find me on <a
					href="https://linkedin.com/in/shinjipons/"
					target="_blank">LinkedIn</a
				>, <a href="https://x.com/shinjipons" target="_blank">Twitter</a> or book
				a call via <a href="https://cal.com/shinjipons" target="_blank"
					>Cal.com</a
				>.
			</p>
		</section>

		<!-- Gallery Section -->
		<section id="gallery">
			<h1>Gallery</h1>
			<div class="gallery-container">
				{
					galleryImages.map((src) => (
						<div
							class="gallery-item"
							tabindex="0"
							role="button"
							aria-haspopup="dialog"
							aria-label="Open in fullscreen"
						>
							{/\.(mp4|mov|webm)$/i.test(src) ? (
								<video src={src} autoplay loop muted playsinline />
							) : (
								<img src={src} alt="" />
							)}
						</div>
					))
				}
			</div>
			<div
				id="gallery-lightbox"
				class="gallery-lightbox"
				hidden
				role="dialog"
				aria-modal="true"
				aria-label="Gallery fullscreen"
			>
				<img
					class="gallery-lightbox-img"
					alt=""
					tabindex="-1"
					hidden
				/>
				<video
					class="gallery-lightbox-video"
					controls
					playsinline
					tabindex="-1"
					hidden
				></video>
			</div>
		</section>

		<!-- Blog Posts Section -->
		<section id="writing">
			<h1>Writing</h1>
			{
				blogPosts.length > 0 ? (
					<div>
						{blogPosts.map((post) => (
							<a href={`/writing/${post.id}`} class="generic-card">
								<p class="date-year">
									{post.data.pubDate.toLocaleDateString("en-US", {
										year: "numeric",
										// month: "long",
										// day: "2-digit",
									})}
								</p>
								<h3 class="title">{post.data.title}</h3>
								<p class="date-monthday">
									{post.data.pubDate.toLocaleDateString("en-US", {
										// year: "numeric",
										month: "long",
										day: "2-digit",
									})}
								</p>
							</a>
						))}
					</div>
				) : (
					<p>Check back soon...</p>
				)
			}
		</section>

		<!-- Work Projects Section -->
		<section id="projects">
			<h1>Projects</h1>
			{
				workProjects.length > 0 ? (
					<div class="cards-container">
						{workProjects.map((project) => (
							<a
								href={project.url}
								target="_blank"
								rel="noopener noreferrer"
								class="generic-card"
							>
								<h3>{project.name}</h3>
								<p>{project.description}</p>
							</a>
						))}
					</div>
				) : (
					<p>Check back soon...</p>
				)
			}
		</section>

		<!-- Work Experience Section -->
		<section id="experience">
			<h1>Work Experience</h1>
			<div>
				{
					workExperience.map((job) => (
						<div class="work-experience-card">
							<p class="work-experience-company">
								{job.url ? (
									<a href={job.url} target="_blank" rel="noopener noreferrer">
										{job.company}
									</a>
								) : (
									<span>{job.company}</span>
								)}
							</p>
							<p class="work-experience-role">{job.role}</p>
							<p class="work-experience-period">{job.period}</p>
						</div>
					))
				}
			</div>
		</section>

		<!-- Side Projects Section -->
		<section id="side-projects">
			<h1>Side Projects</h1>
			{
				sideProjects.length > 0 ? (
					<div class="cards-container">
						{sideProjects.map((project) => (
							<a
								href={project.url}
								target="_blank"
								rel="noopener noreferrer"
								class="generic-card"
							>
								<h3>{project.name}</h3>
								<p>{project.description}</p>
							</a>
						))}
					</div>
				) : (
					<p>Check back soon...</p>
				)
			}
		</section>

		<!-- Experiments Section -->
		<section id="experiments">
			<h1>Experiments</h1>
			{
				experiments.length > 0 ? (
					<div class="cards-container">
						{experiments.map((experiment) => {
							return (
								<a
									href={experiment.url}
									target="_blank"
									rel="noopener noreferrer"
									class="generic-card"
								>
									<h3>{experiment.title}</h3>
									<p>{experiment.description}</p>
								</a>
							);
						})}
					</div>
				) : (
					<p>Coming soon...</p>
				)
			}
		</section>
	</div>

	<script>
		function initGalleryLightbox() {
			const container = document.querySelector(".gallery-container");
			const lightbox = document.getElementById("gallery-lightbox");
			if (!container || !lightbox) return;

			const lbImg = lightbox.querySelector(
				".gallery-lightbox-img",
			) as HTMLImageElement;
			const lbVideo = lightbox.querySelector(
				".gallery-lightbox-video",
			) as HTMLVideoElement;
			const closeBtn = lightbox.querySelector(
				".gallery-lightbox-close",
			) as HTMLButtonElement | null;

			let lastFocus: HTMLElement | null = null;
			/** Cancels an in-flight close animation (e.g. user opens another item). */
			let cancelCloseAnimation: (() => void) | null = null;

			function scrollbarWidthPx() {
				const root = document.documentElement;
				return Math.max(0, window.innerWidth - root.clientWidth);
			}

			function lockDocumentScroll() {
				const root = document.documentElement;
				const sb = scrollbarWidthPx();
				if (sb > 0) {
					const pad = parseFloat(getComputedStyle(root).paddingRight);
					const base = Number.isFinite(pad) ? pad : 0;
					root.style.paddingRight = `${base + sb}px`;
				}
				root.style.overflow = "hidden";
				document.body.style.overflow = "hidden";
			}

			function unlockDocumentScroll() {
				const root = document.documentElement;
				root.style.overflow = "";
				root.style.paddingRight = "";
				document.body.style.overflow = "";
			}

			const CLOSE_ANIM_MS = 150;

			function teardownLightbox() {
				lightbox.hidden = true;
				lightbox.classList.remove("is-open", "is-closing");
				unlockDocumentScroll();
				lbVideo.pause();
				lbVideo.removeAttribute("src");
				lbVideo.hidden = true;
				lbImg.removeAttribute("src");
				lbImg.hidden = true;
				document.removeEventListener("keydown", onKeyDown);
				lastFocus?.focus();
				lastFocus = null;
			}

			function close() {
				if (lightbox.hidden || lightbox.classList.contains("is-closing")) {
					return;
				}

				document.removeEventListener("keydown", onKeyDown);

				lightbox.classList.remove("is-open");
				lightbox.classList.add("is-closing");

				let settled = false;
				const settle = () => {
					if (settled) return;
					settled = true;
					cancelCloseAnimation = null;
					lightbox.removeEventListener("animationend", onAnimEnd);
					window.clearTimeout(fallbackTimer);
					teardownLightbox();
				};

				const onAnimEnd = (e: AnimationEvent) => {
					if (e.target !== lightbox) return;
					if (e.animationName !== "gallery-lightbox-fade-out") return;
					settle();
				};

				lightbox.addEventListener("animationend", onAnimEnd);
				const fallbackTimer = window.setTimeout(settle, CLOSE_ANIM_MS + 80);

				cancelCloseAnimation = () => {
					settled = true;
					cancelCloseAnimation = null;
					lightbox.removeEventListener("animationend", onAnimEnd);
					window.clearTimeout(fallbackTimer);
					lightbox.classList.remove("is-closing");
				};
			}

			function onKeyDown(e: KeyboardEvent) {
				if (e.key === "Escape") close();
			}

			function open(media: HTMLImageElement | HTMLVideoElement) {
				cancelCloseAnimation?.();

				lastFocus = document.activeElement as HTMLElement;
				lockDocumentScroll();
				lightbox.hidden = false;
				lightbox.classList.add("is-open");
				document.addEventListener("keydown", onKeyDown);

				if (media instanceof HTMLImageElement) {
					lbVideo.hidden = true;
					lbVideo.pause();
					lbVideo.removeAttribute("src");
					lbImg.src = media.currentSrc || media.src;
					lbImg.alt = media.alt;
					lbImg.hidden = false;
				} else {
					lbImg.hidden = true;
					lbImg.removeAttribute("src");
					lbVideo.hidden = false;
					lbVideo.src = media.currentSrc || media.src;
					void lbVideo.play().catch(() => {});
				}

				if (closeBtn) {
					closeBtn.focus();
				} else if (!lbImg.hidden) {
					lbImg.focus();
				} else if (!lbVideo.hidden) {
					lbVideo.focus();
				}
			}

			container.addEventListener("click", (e) => {
				const item = (e.target as Element).closest(".gallery-item");
				if (!item || !container.contains(item)) return;
				const media = item.querySelector("img, video");
				if (
					media instanceof HTMLImageElement ||
					media instanceof HTMLVideoElement
				) {
					e.preventDefault();
					open(media);
				}
			});

			container.addEventListener("keydown", (e: KeyboardEvent) => {
				if (e.key !== "Enter" && e.key !== " ") return;
				const item = (e.target as Element).closest(".gallery-item");
				if (!item || !container.contains(item)) return;
				const media = item.querySelector("img, video");
				if (
					media instanceof HTMLImageElement ||
					media instanceof HTMLVideoElement
				) {
					e.preventDefault();
					open(media);
				}
			});

			lightbox.addEventListener("click", (e) => {
				if (e.target === lightbox) close();
			});

			closeBtn?.addEventListener("click", () => close());

			lbImg.addEventListener("click", () => close());
		}

		initGalleryLightbox();
	</script>
</BaseLayout>

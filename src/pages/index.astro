// Format dates for display and filter out past events
const today = new Date();
today.setHours(0, 0, 0, 0); // Set to start of day for accurate comparison

// Get all blog posts dynamically and sort by date (newest first)
const allPosts = await getCollection("writing");
const blogPosts = allPosts.sort(
	(a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

// Archive images — auto-scanned from public/media/archive/
const archiveGlob = import.meta.glob(
	"/public/media/archive/**/*.{jpg,jpeg,png,webp,gif,avif,JPG,JPEG,PNG,WEBP,GIF,AVIF}",
);
const archiveImages = Object.keys(archiveGlob)
	.map((path) => path.replace("/public", ""))
	.sort();
---

<BaseLayout title="Shinji Pons" description="Personal website">
	<div class="container">
		<!-- Header section -->
		<section id="introduction">
			<h1>Shinji Pons</h1>
			<h3>Updated on {lastUpdated}</h3>
		</section>
		<section>
			<p>I was born in Tokyo and now live in Budapest, Hungary.</p>
			<p>
				I'm a senior product designer at <a
					href="https://formlabs.com/"
					target="_blank">Formlabs</a
				>, where I work on software that makes professional-grade 3D printing
				more intuitive. Previously, I worked at Autodesk, LEGO, Shapr3D and
				Electronic Arts.
			</p>
			<p>
				I care about the full picture: how something looks, how it works, how it
				feels on the first use and the thousandth. I'm drawn to complexity that
				rewards patience: hardware-adjacent flows, emerging workflows, and the
				small details that separate good from exceptional.
			</p>
			<p>My approach is simple: do less, but better than everyone else.</p>
			<p>
				You can find me on <a
					href="https://linkedin.com/in/shinjipons/"
					target="_blank">LinkedIn</a
				>, <a href="https://x.com/shinjipons" target="_blank">Twitter</a> or book
				a call via <a href="https://cal.com/shinjipons" target="_blank"
					>Cal.com</a
				>.
			</p>
		</section>

		<!-- Blog Posts Section -->
		<section id="writing">
			<h1>Writing</h1>
			{
				blogPosts.length > 0 ? (
					<div>
						{blogPosts.map((post) => (
							<a href={`/writing/${post.id}`} class="generic-card">
								<p class="date-year">
									{post.data.pubDate.toLocaleDateString("en-US", {
										year: "numeric",
										// month: "long",
										// day: "2-digit",
									})}
								</p>
								<h3 class="title">{post.data.title}</h3>
								<p class="date-monthday">
									{post.data.pubDate.toLocaleDateString("en-US", {
										// year: "numeric",
										month: "long",
										day: "2-digit",
									})}
								</p>
							</a>
						))}
					</div>
				) : (
					<p>Check back soon...</p>
				)
			}
		</section>

		<!-- Work Projects Section -->
		<section id="projects">
			<h1>Projects</h1>
			{
				workProjects.length > 0 ? (
					<div class="cards-container">
						{workProjects.map((project) => (
							<a
								href={project.url}
								target="_blank"
								rel="noopener noreferrer"
								class="generic-card"
							>
								<h3>{project.name}</h3>
								<p>{project.description}</p>
							</a>
						))}
					</div>
				) : (
					<p>Check back soon...</p>
				)
			}
		</section>

		<!-- Work Experience Section -->
		<section id="experience">
			<h1>Work Experience</h1>
			<div>
				{
					workExperience.map((job) => (
						<div class="work-experience-card">
							<p class="work-experience-company">
								{job.url ? (
									<a href={job.url} target="_blank" rel="noopener noreferrer">
										{job.company}
									</a>
								) : (
									<span>{job.company}</span>
								)}
							</p>
							<p class="work-experience-role">{job.role}</p>
							<p class="work-experience-period">{job.period}</p>
						</div>
					))
				}
			</div>
		</section>

		<!-- Side Projects Section -->
		<section id="side-projects">
			<h1>Side Projects</h1>
			{
				sideProjects.length > 0 ? (
					<div class="cards-container">
						{sideProjects.map((project) => (
							<a
								href={project.url}
								target="_blank"
								rel="noopener noreferrer"
								class="generic-card"
							>
								<h3>{project.name}</h3>
								<p>{project.description}</p>
							</a>
						))}
					</div>
				) : (
					<p>Check back soon...</p>
				)
			}
		</section>

		<!-- Experiments Section -->
		<section id="experiments">
			<h1>Experiments</h1>
			{
				experiments.length > 0 ? (
					<div class="cards-container">
						{experiments.map((experiment) => {
							return (
								<a
									href={experiment.url}
									target="_blank"
									rel="noopener noreferrer"
									class="generic-card"
								>
									<h3>{experiment.title}</h3>
									<p>{experiment.description}</p>
								</a>
							);
						})}
					</div>
				) : (
					<p>Coming soon...</p>
				)
			}
		</section>
	</div>
</BaseLayout>

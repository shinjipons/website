---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

// Social media links
const socialLinks = [
  { name: "Resume", url: "/resume-shinji-pons.pdf" },
  { name: "LinkedIn", url: "https://linkedin.com/in/shinjipons" },
  { name: "Twitter", url: "https://x.com/shinjipons" },
  { name: "Cal.com", url: "https://cal.com/shinjipons/" },
  // { name: "Figma", url: "https://www.figma.com/@shinjipons" },
];

// Work experience
const workExperience = [
  {
    company: "Formlabs",
    role: "Product designer",
    period: "2025 — Present",
    url: "https://formlabs.com/",
  },
  {
    company: "Modyfi",
    role: "Product designer",
    period: "2024",
    url: "https://www.modyfi.com/",
  },
  {
    company: "Ragdoll Dynamics",
    role: "Product designer",
    period: "2023 — 2024",
    url: "https://ragdolldynamics.com/",
  },
  {
    company: "Frostbite",
    role: "Product designer",
    period: "2022 — 2023",
    url: "https://www.ea.com/frostbite",
  },
  {
    company: "LEGO",
    role: "Product designer",
    period: "2019 — 2021",
    url: "https://www.lego.com/",
  },
  {
    company: "Autodesk",
    role: "Product designer",
    period: "2017 — 2019",
    url: "https://www.autodesk.com/",
  },
  {
    company: "Thomson Reuters",
    role: "Product designer",
    period: "2016 — 2017",
    url: "https://www.thomsonreuters.com/",
  },
  {
    company: "Microsoft",
    role: "UX designer",
    period: "2015",
    url: "https://www.microsoft.com/",
  },
  {
    company: "Barnbrook",
    role: "Design intern",
    period: "2015",
    url: "https://www.barnbrook.net/",
  },
  {
    company: "The Design Lab",
    role: "Design intern",
    period: "2014",
    url: "https://www.totaldesign.com/",
  },
  {
    company: "Total Design",
    role: "Design intern",
    period: "2013",
    url: "https://designlaboratory.co.uk/",
  },
  {
    company: "Ateliers Jean Nouvel",
    role: "Design intern",
    period: "2012",
    url: "https://www.jeannouvel.com/",
  },
];

// Work projects (most proud projects)
const workProjects = [
  {
    name: "PreForm by Formlabs",
    description: "from v3.51 to 3.56",
    url: "https://formlabs.com/software/preform/",
  },
  {
    name: "Ragdoll Standalone",
    description: "Animating with physics",
    url: "https://ragdolldynamics.com/",
  },
  {
    name: "Modyfi",
    description: "Confidential",
    url: "https://www.modyfi.com/",
  },
  {
    name: "Frostbite",
    description: "Confidential",
    url: "https://www.ea.com/frostbite",
  },
  {
    name: "LEGO Digital Designer Pro",
    description: "Confidential",
    url: "https://www.lego.com/",
  },
  {
    name: "Autodesk Alias SubD",
    description: "SubD modelling in Alias",
    url: "https://autodesk.com/alias",
  },
  {
    name: "Dynamo for Alias",
    description: "Computational design in Alias",
    url: "https://autodesk.com/alias",
  },
  {
    name: "Louvre Abu Dhabi",
    description: "Supergraphics + icon design",
    url: "https://www.jeannouvel.com/projets/louvre-abou-dhabi-3/",
  },
];

// Side projects
const sideProjects = [
  {
    name: "Select Parent Component",
    description: "Select Figma components fast",
    url: "https://github.com/shinjipons/Select-Parent-Component",
  },
  {
    name: "Time Lens",
    description: "Blender screenshot automator",
    url: "https://github.com/shinjipons/Time-Lens",
  },
  {
    name: "Modulo",
    description: "168 grid-based typefaces",
    url: "https://github.com/shinjipons/modulo-typeface",
  },
  {
    name: "InDesign Scripting",
    description: "Automating InDesign",
    url: "https://github.com/shinjipons/basiljs-scripts",
  },
];

// Get all blog posts dynamically and sort by date (newest first)
const allPosts = await getCollection("writing");
const blogPosts = allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

// Archive images — auto-scanned from public/media/archive/
const archiveGlob = import.meta.glob('/public/media/archive/**/*.{jpg,jpeg,png,webp,gif,avif,JPG,JPEG,PNG,WEBP,GIF,AVIF}');
const archiveImages = Object.keys(archiveGlob)
  .map(path => path.replace('/public', ''))
  .sort();

// Experiments
const experiments = [
  {
    title: "Input Field",
    description: "Slider with spinbox design prototype",
    url: "https://spinbox-prototype.shinjipons.com",
    imageLight: "/media/experiments/spinbox-prototype-light-mode.png",
    imageDark: "/media/experiments/spinbox-prototype-dark-mode.png",
    buttonText: "Play",
  }, {
    title: "Luminous SF Icon",
    description: "Icon design for Luminous SF",
    url: "https://www.figma.com/community/file/1440464930979235933",
    imageLight: "/media/experiments/luminous-sf-icon-light-mode.png",
    imageDark: "/media/experiments/luminous-sf-icon-light-mode.png",
    buttonText: "View",
  }
];
---

<BaseLayout title="Shinji Pons is a software designer based in Budapest" description="Personal website">
  <div class="container">

    <!-- Header section -->
    <section>
      <h1>Shinji Pons</h1>
      <p>Product designer</p>
    </section>

    <!-- Today section -->
    <section id="today">
      <h1>Today</h1>
      <p>I make 3D tools and workflows for professional users.</p>
      <div class="social-links">
        {socialLinks.map((link) => (
          <a href={link.url} target="_blank" rel="noopener noreferrer">{link.name}</a>
        ))}
      </div>
    </section>

    <!-- Blog Posts Section -->
    <section id="writing">
      <h1>Writing</h1>
      {
        blogPosts.length > 0 ? (
          <div>
            {blogPosts.map((post) => (
              <div class="blog-card">
                <p>
                  <a href={`/writing/${post.id}`}>{post.data.title}</a>
                </p>
                <div class="blog-card-date">
                  <p>{post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</p>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <p>Check back soon...</p>
        )
      }
    </section>

    <!-- Work Experience Section -->
    <section id="experience">
      <h1>Work Experience</h1>
      <div>
        {
          workExperience.map((job) => (
            <div class="work-experience-card">
              <p>
                {job.url ? (
                  <a href={job.url} target="_blank" rel="noopener noreferrer">{job.company}</a>
                ) : (
                  <span>{job.company}</span>
                )}
              </p>
              <div class="work-experience-card-description">
                <p>{job.role}</p>
                {/* <p>{job.period}</p> */}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Work Projects Section -->
    <section id="projects">
      <h1>Projects</h1>
      {
        workProjects.length > 0 ? (
          <div>
            {workProjects.map((project) => (
              <div class="blog-card">
                <p>
                  <a href={project.url} target="_blank" rel="noopener noreferrer">{project.name}</a>
                </p>
                <div class="blog-card-date">
                  <p>{project.description}</p>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <p>Check back soon...</p>
        )
      }
    </section>

    <!-- Side Projects Section -->
    <section id="side-projects">
      <h1>Side Projects</h1>
      {
        sideProjects.length > 0 ? (
          <div>
            {sideProjects.map((project) => (
              <div class="blog-card">
                <p>
                  <a href={project.url} target="_blank" rel="noopener noreferrer">{project.name}</a>
                </p>
                <div class="blog-card-date">
                  <p>{project.description}</p>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <p>Check back soon...</p>
        )
      }
    </section>

    <!-- Experiments Section -->
    <section id="experiments">
      <h1>Experiments</h1>
      {
        experiments.length > 0 ? (
          <div>
            {experiments.map((experiment) => (
              <div class="blog-card">
                <p>
                  <a href={experiment.url} target="_blank" rel="noopener noreferrer">{experiment.title}</a>
                </p>
                <div class="blog-card-date">
                  <p>{experiment.description}</p>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <p>Coming soon...</p>
        )
      }
    </section>

  </div>

  <!-- Archive and scraps section -->
  <section id="archive-and-scraps">
    <div class="container">
      <h1 style="margin-bottom: 3.2rem;">Archive and Scraps</h1>
    </div>
    {archiveImages.length > 0 ? (
      <>
        <div class="archive-grid">
          {archiveImages.map((src, i) => (
            <div class="archive-item" data-archive-index={i}>
              <img src={src} loading="lazy" decoding="async" alt="" />
            </div>
          ))}
        </div>
        <script type="application/json" id="archive-data" is:inline set:html={JSON.stringify(archiveImages)} />
      </>
    ) : (
      <div class="container">
        <p>Nothing here yet...</p>
      </div>
    )}
  </section>

</BaseLayout>
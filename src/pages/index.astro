		url: "https://github.com/shinjipons/modulo-typeface",
	},
	{
		name: "InDesign Scripting",
		description: "Automating InDesign",
		url: "https://github.com/shinjipons/basiljs-scripts",
	},
];

// Experiments
const experiments = [
	{
		title: "Figma Matcaps",
		description: "Matcaps for Blender",
		url: "https://www.figma.com/community/file/1650617040758495972",
	},
	{
		title: "Random Misdirections [5]",
		description: "Recreating Instagram post",
		url: "https://random-misdirections.shinjipons.com/",
	},
	{
		title: "Tile Shifter",
		description: "Image shifting tool",
		url: "https://tileshifter.shinjipons.com",
	},
	{
		title: "3D Measure Tool",
		description: "PreForm prototype",
		url: "https://3d-measure.shinjipons.com/",
	},
	{
		title: "Input Field",
		description: "Slider with spinbox design",
		url: "https://spinbox-prototype.shinjipons.com",
	},
	{
		title: "Luminous SF Icon",
		description: "Icon design for Luminous SF",
		url: "https://www.figma.com/community/file/1440464930979235933",
	},
];

// Get all blog posts dynamically and sort by date (newest first)
const allPosts = await getCollection("writing");
const blogPosts = allPosts.sort(
	(a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<BaseLayout title="Shinji Pons" description="Personal website">
	<div class="container page-reveal">
		<section id="introduction">
			<h1>Shinji Pons</h1>
			<h3>Updated on {lastUpdated}</h3>
			<p>My expertise lies in the design of 3D tools and workflows.</p>
			<p>
				Right now, I'm taking a short break before I look for my next role.
				Previously, I worked at Formlabs, Autodesk, LEGO, Shapr3D and Electronic
				Arts.
			</p>
			<p>
				I care about the full picture: how something looks, how it works, how it
				feels on the first use and the thousandth. I'm drawn to complexity that
				rewards patience: hardware-adjacent flows, emerging workflows, and the
				small details that separate good from exceptional.
			</p>
			<div class="profile-links">
				{
					profileLinks.map((link) => (
						<a
							class="profile-link"
							href={link.url}
							target="_blank"
							rel="noopener noreferrer"
						>
							<svg
								width="8"
								height="8"
								viewBox="0 0 8 8"
								fill="none"
								xmlns="http://www.w3.org/2000/svg"
								class="profile-link-corner profile-link-corner--top-left"
							>
								<path
									d="M0.5 7.5V0.5H7.5"
									stroke="black"
									stroke-linecap="square"
								/>
							</svg>

							<svg
								width="8"
								height="8"
								viewBox="0 0 8 8"
								fill="none"
								xmlns="http://www.w3.org/2000/svg"
								class="profile-link-corner profile-link-corner--top-right"
							>
								<path
									d="M7.5 7.5V0.5H0.5"
									stroke="black"
									stroke-linecap="square"
								/>
							</svg>

							<svg
								width="8"
								height="8"
								viewBox="0 0 8 8"
								fill="none"
								xmlns="http://www.w3.org/2000/svg"
								class="profile-link-corner profile-link-corner--bottom-right"
							>
								<path
									d="M7.5 0.5V7.5H0.5"
									stroke="black"
									stroke-linecap="square"
								/>
							</svg>

							<svg
								width="8"
								height="8"
								viewBox="0 0 8 8"
								fill="none"
								xmlns="http://www.w3.org/2000/svg"
								class="profile-link-corner profile-link-corner--bottom-left"
							>
								<path
									d="M0.5 0.5V7.5H7.5"
									stroke="black"
									stroke-linecap="square"
								/>
							</svg>

							{link.name}
						</a>
					))
				}
			</div>
		</section>

		<!-- Blog Posts Section -->
		<section id="writing">
			<h1>Writing</h1>
			{
				blogPosts.length > 0 ? (
					<div class="cards-container">
						{blogPosts.map((post) => (
							<a href={`/writing/${post.id}`} class="generic-card">
								<p class="date-year">
									{post.data.pubDate.toLocaleDateString("en-US", {
										year: "numeric",
										// month: "long",
										// day: "2-digit",
									})}
								</p>
								<h3 class="title">{post.data.title}</h3>
								<p class="date-monthday">
									{post.data.pubDate.toLocaleDateString("en-US", {
										// year: "numeric",
										month: "long",
										day: "2-digit",
									})}
								</p>
							</a>
						))}
					</div>
				) : (
					<p>Check back soon...</p>
				)
			}
		</section>

		<!-- Work Projects Section -->
		<section id="projects">
			<h1>Projects</h1>
			{
				workProjects.length > 0 ? (
					<div class="cards-container">
						{workProjects.map((project) => (
							<a
								href={project.url}
								target="_blank"
								rel="noopener noreferrer"
								class="generic-card"
							>
								<h3 class="project-name">{project.name}</h3>
								<p class="project-description">{project.description}</p>
							</a>
						))}
					</div>
				) : (
					<p>Check back soon...</p>
				)
			}
		</section>

		<!-- Work Experience Section -->
		<section id="experience">
			<h1>Work Experience</h1>
			<div class="cards-container">
				{
					workExperience.map((job) => (
						<a
							href={job.url}
							target="_blank"
							rel="noopener noreferrer"
							class="generic-card"
						>
							<p class="work-experience-company">{job.company}</p>
							<h3 class="work-experience-role">{job.role}</h3>
							<p class="work-experience-period">{job.period}</p>
						</a>
					))
				}
			</div>
		</section>

		<!-- Side Projects Section -->
		<section id="side-projects">
			<h1>Side Projects</h1>
			{
				sideProjects.length > 0 ? (
					<div class="cards-container">
						{sideProjects.map((project) => (
							<a
								href={project.url}
								target="_blank"
								rel="noopener noreferrer"
								class="generic-card"
							>
								<h3 class="project-name">{project.name}</h3>
								<p class="project-description">{project.description}</p>
							</a>
						))}
					</div>
				) : (
					<p>Check back soon...</p>
				)
			}
		</section>

		<!-- Experiments Section -->
		<section id="experiments">
			<h1>Experiments</h1>
			{
				experiments.length > 0 ? (
					<div class="cards-container">
						{experiments.map((experiment) => {
							return (
								<a
									href={experiment.url}
									target="_blank"
									rel="noopener noreferrer"
									class="generic-card"
								>
									<h3 class="project-name">{experiment.title}</h3>
									<p class="project-description">{experiment.description}</p>
								</a>
							);
						})}
					</div>
				) : (
					<p>Coming soon...</p>
				)
			}
		</section>
	</div>

	<script>
		import { initPageReveal } from "../scripts/page-reveal.ts";

		initPageReveal(
			document.querySelector(".container"),
			"#introduction > h1, #introduction > h3, #introduction > p, #introduction .profile-links a, section > h1, section > p, .generic-card",
		);
	</script>
</BaseLayout>

		</section>

		{/*
		<section id="grid-gallery">
			<h1>Archive</h1>
			{
				gridGalleryImages.length > 0 ? (
					<div class="grid-gallery">
						{gridGalleryImages.map((src) => (
							<button
								type="button"
								class="grid-gallery__cell"
								aria-haspopup="dialog"
								aria-label="Open in fullscreen"
							>
								{/\.(mp4|mov|webm)$/i.test(src) ? (
									<video
										src={src}
										muted
										loop
										playsinline
										controlslist="nodownload nofullscreen noremoteplayback"
									/>
								) : (
									<img src={src} alt="" loading="lazy" decoding="async" />
								)}
							</button>
						))}
					</div>
				) : (
					<p>Check back soon...</p>
				)
			}
		</section>
		*/}
	</div>

	<script>
		function initGalleryLightbox() {
			const lightbox = document.getElementById("gallery-lightbox");
			if (!lightbox) return;

			const lbImg = lightbox.querySelector(
				".gallery-lightbox-img",
			) as HTMLImageElement;
			const lbVideo = lightbox.querySelector(
				".gallery-lightbox-video",
			) as HTMLVideoElement;
			const closeBtn = lightbox.querySelector(
				".gallery-lightbox-close",
			) as HTMLButtonElement | null;

			let lastFocus: HTMLElement | null = null;
			/** Cancels an in-flight close animation (e.g. user opens another item). */
			let cancelCloseAnimation: (() => void) | null = null;
			let playlist: (HTMLImageElement | HTMLVideoElement)[] = [];
			let currentIndex = -1;

			function scrollbarWidthPx() {
				const root = document.documentElement;
				return Math.max(0, window.innerWidth - root.clientWidth);
			}

			function lockDocumentScroll() {
				const root = document.documentElement;
				const sb = scrollbarWidthPx();
				if (sb > 0) {
					const pad = parseFloat(getComputedStyle(root).paddingRight);
					const base = Number.isFinite(pad) ? pad : 0;
					root.style.paddingRight = `${base + sb}px`;
				}
				root.style.overflow = "hidden";
				document.body.style.overflow = "hidden";
			}

			function unlockDocumentScroll() {
				const root = document.documentElement;
				root.style.overflow = "";
				root.style.paddingRight = "";
				document.body.style.overflow = "";
			}

			const CLOSE_ANIM_MS = 150;

			function teardownLightbox() {
				lightbox.hidden = true;
				lightbox.classList.remove("is-open", "is-closing");
				unlockDocumentScroll();
				lbVideo.pause();
				lbVideo.removeAttribute("src");
				lbVideo.hidden = true;
				lbImg.removeAttribute("src");
				lbImg.hidden = true;
				document.removeEventListener("keydown", onKeyDown);
				lastFocus?.focus();
				lastFocus = null;
				playlist = [];
				currentIndex = -1;
			}

			function close() {
				if (lightbox.hidden || lightbox.classList.contains("is-closing")) {
					return;
				}

				document.removeEventListener("keydown", onKeyDown);

				lightbox.classList.remove("is-open");
				lightbox.classList.add("is-closing");

				let settled = false;
				const settle = () => {
					if (settled) return;
					settled = true;
					cancelCloseAnimation = null;
					lightbox.removeEventListener("animationend", onAnimEnd);
					window.clearTimeout(fallbackTimer);
					teardownLightbox();
				};

				const onAnimEnd = (e: AnimationEvent) => {
					if (e.target !== lightbox) return;
					if (e.animationName !== "gallery-lightbox-fade-out") return;
					settle();
				};

				lightbox.addEventListener("animationend", onAnimEnd);
				const fallbackTimer = window.setTimeout(settle, CLOSE_ANIM_MS + 80);

				cancelCloseAnimation = () => {
					settled = true;
					cancelCloseAnimation = null;
					lightbox.removeEventListener("animationend", onAnimEnd);
					window.clearTimeout(fallbackTimer);
					lightbox.classList.remove("is-closing");
				};
			}

			const gridMediaSelector =
				".grid-gallery__cell img, .grid-gallery__cell video";

			function mediaSrc(media: HTMLImageElement | HTMLVideoElement) {
				return media.currentSrc || media.src;
			}

			function buildPlaylist(
				media: HTMLImageElement | HTMLVideoElement,
			): (HTMLImageElement | HTMLVideoElement)[] {
				const grid = document.querySelector(".grid-gallery");
				if (grid?.contains(media)) {
					return Array.from(grid.querySelectorAll(gridMediaSelector)) as (
						| HTMLImageElement
						| HTMLVideoElement
					)[];
				}

				const gallery = document.querySelector(".gallery-container");
				if (gallery?.contains(media)) {
					const items: (HTMLImageElement | HTMLVideoElement)[] = [];
					gallery.querySelectorAll(".gallery-item").forEach((item) => {
						const el = item.querySelector(
							".gallery-item-face--front img, .gallery-item-face--front video",
						);
						if (
							el instanceof HTMLImageElement ||
							el instanceof HTMLVideoElement
						) {
							items.push(el);
						}
					});
					return items;
				}

				return [media];
			}

			function indexInPlaylist(media: HTMLImageElement | HTMLVideoElement) {
				const direct = playlist.indexOf(media);
				if (direct >= 0) return direct;
				const src = mediaSrc(media);
				return playlist.findIndex((m) => mediaSrc(m) === src);
			}

			function showPlaylistIndex(index: number) {
				if (index < 0 || index >= playlist.length) return;

				cancelCloseAnimation?.();
				currentIndex = index;
				const media = playlist[currentIndex];

				if (media instanceof HTMLImageElement) {
					lbVideo.hidden = true;
					lbVideo.pause();
					lbVideo.removeAttribute("src");
					lbImg.src = mediaSrc(media);
					lbImg.alt = media.alt;
					lbImg.hidden = false;
				} else {
					lbImg.hidden = true;
					lbImg.removeAttribute("src");
					lbVideo.hidden = false;
					lbVideo.src = mediaSrc(media);
					void lbVideo.play().catch(() => {});
				}
			}

			function focusLightboxControls() {
				closeBtn?.focus();
			}

			function onKeyDown(e: KeyboardEvent) {
				if (e.key === "Escape") {
					close();
					return;
				}

				if (
					lightbox.hidden ||
					!lightbox.classList.contains("is-open") ||
					lightbox.classList.contains("is-closing")
				) {
					return;
				}

				if (playlist.length < 2) return;

				if (e.key === "ArrowLeft") {
					e.preventDefault();
					showPlaylistIndex(
						(currentIndex - 1 + playlist.length) % playlist.length,
					);
				} else if (e.key === "ArrowRight") {
					e.preventDefault();
					showPlaylistIndex((currentIndex + 1) % playlist.length);
				}
			}

			function open(media: HTMLImageElement | HTMLVideoElement) {
				playlist = buildPlaylist(media);
				const idx = indexInPlaylist(media);
				currentIndex = idx >= 0 ? idx : 0;

				const isFirstOpen = lightbox.hidden;
				if (isFirstOpen) {
					lastFocus = document.activeElement as HTMLElement;
					lockDocumentScroll();
					lightbox.hidden = false;
					lightbox.classList.add("is-open");
					document.addEventListener("keydown", onKeyDown);
				}

				showPlaylistIndex(currentIndex);
				focusLightboxControls();
			}

			const GALLERY_MEDIA_SELECTOR =
				".gallery-item-face--front img, .gallery-item-face--front video, .gallery-item-face--back img, .gallery-item-face--back video";

			function registerLightboxContainer(
				container: Element | null,
				mediaSelector: string,
				keyboardItemSelector: string,
				keyboardMediaSelector: string,
			) {
				if (!container) return;

				function mediaUnderPoint(
					clientX: number,
					clientY: number,
				): HTMLImageElement | HTMLVideoElement | null {
					const stack = document.elementsFromPoint(clientX, clientY);
					for (let i = 0; i < stack.length; i++) {
						const el = stack[i];
						if (
							(el instanceof HTMLImageElement ||
								el instanceof HTMLVideoElement) &&
							container.contains(el) &&
							el.matches(mediaSelector)
						) {
							return el;
						}
					}
					return null;
				}

				container.addEventListener("click", (e) => {
					const me = e as MouseEvent;
					const media = mediaUnderPoint(me.clientX, me.clientY);
					if (!media) return;
					e.preventDefault();
					open(media);
				});

				container.addEventListener("keydown", (e: KeyboardEvent) => {
					if (e.key !== "Enter" && e.key !== " ") return;
					const item = (e.target as Element).closest(keyboardItemSelector);
					if (!item || !container.contains(item)) return;
					const media = item.querySelector(keyboardMediaSelector);
					if (
						media instanceof HTMLImageElement ||
						media instanceof HTMLVideoElement
					) {
						e.preventDefault();
						open(media);
					}
				});
			}

			registerLightboxContainer(
				document.querySelector(".gallery-container"),
				GALLERY_MEDIA_SELECTOR,
				".gallery-item",
				".gallery-item-face--front img, .gallery-item-face--front video, .gallery-item-face--back img, .gallery-item-face--back video",
			);

			registerLightboxContainer(
				document.querySelector(".grid-gallery"),
				gridMediaSelector,
				".grid-gallery__cell",
				gridMediaSelector,
			);

			lightbox.addEventListener("click", (e) => {
				if (e.target === lightbox) close();
			});

			closeBtn?.addEventListener("click", () => close());

			lbImg.addEventListener("click", () => close());
			lbVideo.addEventListener("click", () => close());
		}

		/**
		 * Drive the sphere's Y rotation from rAF and let the user grab it
		 * with the mouse / touch to rotate manually, with momentum on release.
		 *
		 * Why rAF instead of CSS animation:
		 * Browsers throttle compositor-driven CSS animations when the animated
		 * element is (partly) offscreen as a power-saving optimization, which
		 * shows up here as visibly skipped frames once the gallery scrolls out
		 * of view. rAF is only throttled when the document is hidden, so this
		 * keeps the rotation smooth regardless of scroll position.
		 *
		 * Motion model:
		 * The sphere is always in a "coast" state described by an initial
		 * velocity v0 at time t0 (= release time), decaying exponentially
		 * toward the steady-state auto-rotation velocity vAuto:
		 *
		 *     v(t)     = vAuto + (v0 - vAuto) * exp(-t / TAU)
		 *     angle(t) = θ0 + vAuto·t + (v0 - vAuto)·TAU·(1 - exp(-t / TAU))
		 *
		 * Idle auto-rotation is just the special case v0 == vAuto (the decay
		 * term vanishes), so the same loop handles both "ambient spin" and
		 * "post-flick coast" with no state machine.
		 *
		 * Drag model:
		 * - Pointer down on .gallery-pivot pauses the coast.
		 * - Horizontal movement maps 1 pivot width → 360°.
		 * - On release we sample the angular velocity from a short trailing
		 *   window of move events (so the velocity reflects the user's
		 *   *final* gesture, not the average of the whole drag) and seed a
		 *   fresh coast with that velocity.
		 * - A drag past the threshold suppresses the next click so the
		 *   lightbox doesn't open at the end of a gesture.
		 */
		function initGallerySphere() {
			const pivot = document.querySelector(
				".gallery-pivot",
			) as HTMLElement | null;
			const sphere = document.querySelector(
				".gallery-sphere",
			) as HTMLElement | null;
			if (!pivot || !sphere) return;

			const reduceMotion = window.matchMedia(
				"(prefers-reduced-motion: reduce)",
			);

			function readDurationMs(): number {
				const raw = getComputedStyle(document.documentElement)
					.getPropertyValue("--gallery-sphere-rotate-duration")
					.trim();
				if (!raw) return 96000;
				if (raw.endsWith("ms")) return parseFloat(raw);
				if (raw.endsWith("s")) return parseFloat(raw) * 1000;
				const n = parseFloat(raw);
				return Number.isFinite(n) && n > 0 ? n : 96000;
			}

			const norm = (a: number) => ((a % 360) + 360) % 360;

			// Tuning knobs for the inertial coast.
			const TAU_MS = 350; // time constant — ~3·TAU until coast is indistinguishable from auto
			const SAMPLE_WINDOW_MS = 80; // trailing window for release-velocity sampling
			const MAX_FLICK_DEG_PER_MS = 2; // hard cap on |v0| (~5.5 turns/sec)
			const DRAG_THRESHOLD_PX = 4;

			let durationMs = readDurationMs();
			let angleDeg = 0;
			let rafId = 0;
			let coastStartTime = 0;
			let coastStartAngle = 0;
			let coastVelocity = 0; // deg/ms

			const autoVelocity = () => 360 / durationMs;

			function angleAtTime(now: number): number {
				const vAuto = autoVelocity();
				const t = now - coastStartTime;
				return (
					coastStartAngle +
					vAuto * t +
					(coastVelocity - vAuto) * TAU_MS * (1 - Math.exp(-t / TAU_MS))
				);
			}

			function apply() {
				sphere!.style.transform = `rotateY(${angleDeg}deg)`;
			}

			function tick(now: number) {
				angleDeg = norm(angleAtTime(now));
				apply();
				rafId = requestAnimationFrame(tick);
			}

			function startCoast(initialVelocity: number) {
				durationMs = readDurationMs();
				sphere!.style.animation = "none";
				coastStartTime = performance.now();
				coastStartAngle = angleDeg;
				coastVelocity = initialVelocity;
				if (rafId === 0) rafId = requestAnimationFrame(tick);
			}

			function stopLoop() {
				if (rafId === 0) return;
				cancelAnimationFrame(rafId);
				rafId = 0;
			}

			// Drag state + velocity sampling buffer.
			let dragging = false;
			let dragPointerId = -1;
			let dragStartX = 0;
			let dragStartUnwrapped = 0;
			let dragUnwrappedAngle = 0;
			let dragMoved = false;

			type Sample = { t: number; angle: number };
			let dragSamples: Sample[] = [];

			function pushSample(t: number, unwrappedAngle: number) {
				dragSamples.push({ t, angle: unwrappedAngle });
				while (
					dragSamples.length > 0 &&
					t - dragSamples[0].t > SAMPLE_WINDOW_MS
				) {
					dragSamples.shift();
				}
			}

			function computeReleaseVelocity(): number {
				if (dragSamples.length < 2) return autoVelocity();
				const oldest = dragSamples[0];
				const newest = dragSamples[dragSamples.length - 1];
				const dt = newest.t - oldest.t;
				if (dt < 1) return autoVelocity();
				let v = (newest.angle - oldest.angle) / dt;
				if (v > MAX_FLICK_DEG_PER_MS) v = MAX_FLICK_DEG_PER_MS;
				else if (v < -MAX_FLICK_DEG_PER_MS) v = -MAX_FLICK_DEG_PER_MS;
				return v;
			}

			const prevBodyCursor = { value: "" };
			const prevBodyUserSelect = { value: "" };

			function onPointerDown(e: PointerEvent) {
				if (e.button !== 0) return;
				dragging = true;
				dragPointerId = e.pointerId;
				dragStartX = e.clientX;
				dragStartUnwrapped = angleDeg;
				dragUnwrappedAngle = angleDeg;
				dragMoved = false;
				dragSamples = [];
				pushSample(e.timeStamp || performance.now(), dragUnwrappedAngle);

				stopLoop();
				sphere!.style.animation = "none";

				try {
					pivot!.setPointerCapture(e.pointerId);
				} catch {}

				prevBodyCursor.value = document.body.style.cursor;
				prevBodyUserSelect.value = document.body.style.userSelect;
				document.body.style.cursor = "grabbing";
				document.body.style.userSelect = "none";
				pivot!.style.cursor = "grabbing";
			}

			function onPointerMove(e: PointerEvent) {
				if (!dragging || e.pointerId !== dragPointerId) return;
				const dx = e.clientX - dragStartX;
				if (!dragMoved && Math.abs(dx) > DRAG_THRESHOLD_PX) dragMoved = true;
				const width = pivot!.clientWidth || 1;
				dragUnwrappedAngle = dragStartUnwrapped + (dx / width) * 360;
				angleDeg = norm(dragUnwrappedAngle);
				apply();
				pushSample(e.timeStamp || performance.now(), dragUnwrappedAngle);
			}

			function endDrag(e: PointerEvent) {
				if (!dragging || e.pointerId !== dragPointerId) return;
				dragging = false;
				dragPointerId = -1;
				try {
					pivot!.releasePointerCapture(e.pointerId);
				} catch {}

				// Make sure the release position itself is in the velocity window —
				// pointerup may carry a different coord than the last pointermove.
				const dx = e.clientX - dragStartX;
				const width = pivot!.clientWidth || 1;
				dragUnwrappedAngle = dragStartUnwrapped + (dx / width) * 360;
				angleDeg = norm(dragUnwrappedAngle);
				pushSample(e.timeStamp || performance.now(), dragUnwrappedAngle);

				document.body.style.cursor = prevBodyCursor.value;
				document.body.style.userSelect = prevBodyUserSelect.value;
				pivot!.style.cursor = "grab";

				if (dragMoved) {
					// Swallow the click that would otherwise open the lightbox at the
					// end of a drag. Capture phase so it fires before the bubble-phase
					// handler registered in initGalleryLightbox().
					const suppress = (ev: Event) => {
						ev.stopPropagation();
						ev.preventDefault();
					};
					const opts = { capture: true, once: true } as AddEventListenerOptions;
					window.addEventListener("click", suppress, opts);
					window.setTimeout(() => {
						window.removeEventListener("click", suppress, { capture: true });
					}, 300);
				}

				if (!reduceMotion.matches) startCoast(computeReleaseVelocity());
			}

			pivot.style.cursor = "grab";
			pivot.addEventListener("pointerdown", onPointerDown);
			pivot.addEventListener("pointermove", onPointerMove);
			pivot.addEventListener("pointerup", endDrag);
			pivot.addEventListener("pointercancel", endDrag);
			pivot.addEventListener("dragstart", (e) => e.preventDefault());

			if (!reduceMotion.matches) startCoast(autoVelocity());

			reduceMotion.addEventListener("change", (e) => {
				if (e.matches) {
					stopLoop();
					sphere!.style.animation = "";
					sphere!.style.transform = "";
				} else {
					startCoast(autoVelocity());
				}
			});
		}

		initGalleryLightbox();
		initGallerySphere();
	</script>
</BaseLayout>

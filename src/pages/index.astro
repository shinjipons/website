		description: "Computational design in Alias",
		url: "https://autodesk.com/alias",
	},
	{
		name: "Louvre Abu Dhabi",
		description: "Supergraphics and icon design",
		url: "https://www.jeannouvel.com/projets/louvre-abou-dhabi-3/",
	},
];

// Side projects
const sideProjects = [
	{
		name: "Select Parent Component",
		description: "Quickly select Figma components",
		url: "https://github.com/shinjipons/Select-Parent-Component",
	},
	{
		name: "Time Lens",
		description: "Automate Blender editor screenshots",
		url: "https://github.com/shinjipons/Time-Lens",
	},
	{
		name: "Modulo",
		description: "168 grid-based typefaces",
		url: "https://github.com/shinjipons/modulo-typeface",
	},
	{
		name: "InDesign Scripting",
		description: "Automating InDesign",
		url: "https://github.com/shinjipons/basiljs-scripts",
	},
];

// Format dates for display and filter out past events
const today = new Date();
today.setHours(0, 0, 0, 0); // Set to start of day for accurate comparison

const upcomingEvents = upcomingEventsRaw
	.filter((event) => {
		if (!event.date) return true; // Keep events without dates
		const eventDate = new Date(event.date + "T00:00:00");
		eventDate.setHours(0, 0, 0, 0);
		return eventDate >= today; // Only include today and future events
	})
	.sort((a, b) => {
		// Sort events without dates to the end
		if (!a.date) return 1;
		if (!b.date) return -1;
		// Sort by date in chronological order (earliest first)
		return (
			new Date(a.date + "T00:00:00").getTime() -
			new Date(b.date + "T00:00:00").getTime()
		);
	})
	.map((event) => ({
		...event,
		date: event.date ? formatEventDate(event.date) : undefined,
	}));

// Get all blog posts dynamically and sort by date (newest first)
const allPosts = await getCollection("writing");
const blogPosts = allPosts.sort(
	(a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

// Archive images — auto-scanned from public/media/archive/
const archiveGlob = import.meta.glob(
	"/public/media/archive/**/*.{jpg,jpeg,png,webp,gif,avif,JPG,JPEG,PNG,WEBP,GIF,AVIF}",
);
const archiveImages = Object.keys(archiveGlob)
	.map((path) => path.replace("/public", ""))
	.sort();

// Experiments
const experiments = [
	{
		title: "Input Field",
		description: "Slider with spinbox design prototype",
		url: "https://spinbox-prototype.shinjipons.com",
	},
	{
		title: "Luminous SF Icon",
		description: "Icon design for Luminous SF",
		url: "https://www.figma.com/community/file/1440464930979235933",
	},
];
---

<BaseLayout title="Shinji Pons" description="Personal website">
	<div class="container">
		<!-- Header section -->
		<section id="introduction">
			<h1>Shinji Pons</h1>
			<h3>Updated on {lastUpdated}</h3>
		</section>
		<section>
			<p>I was born in Tokyo and now live in Budapest, Hungary.</p>
			<p>
				I'm a senior product designer at <a
					href="https://formlabs.com/"
					target="_blank">Formlabs</a
				>, where I work on software that makes professional-grade 3D printing
				more intuitive. Previously, I worked at Autodesk, LEGO, Shapr3D and
				Electronic Arts.
			</p>
			<p>
				I care about the full picture: how something looks, how it works, how it
				feels on the first use and the thousandth. I'm drawn to complexity that
				rewards patience: hardware-adjacent flows, emerging workflows, and the
				small details that separate good from exceptional.
			</p>
			<p>My approach is simple: do less, but better than everyone else.</p>
			<p>
				You can find me on <a
					href="https://linkedin.com/in/shinjipons/"
					target="_blank">LinkedIn</a
				>, <a href="https://x.com/shinjipons" target="_blank">Twitter</a> or book
				a call via <a href="https://cal.com/shinjipons" target="_blank"
					>Cal.com</a
				>.
			</p>
		</section>


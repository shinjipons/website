---
import { getCollection } from "astro:content";
import { execSync } from "node:child_process";

const lastUpdated = new Date(
	execSync("git log -1 --format=%cd --date=format:%Y-%m-%d").toString().trim(),
).toLocaleDateString("en-US", {
	year: "numeric",
	month: "long",
	day: "2-digit",
});
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/home-page.css";

// Upcoming events and meetups
const upcomingEventsRaw = [
	{
		title: "Stop Designing Your Own Chaos - CraftHub x UX Budapest",
		destination: "Budapest",
		date: "2026-03-30",
		url: "https://luma.com/n0e4tal9?tk=3dtDp8",
	},
	{
		title: "SEON TechTalks",
		destination: "Budapest",
		date: "2026-04-16",
		url: "https://luma.com/seontechtalks?tk=LivIBU",
	},
];

// Format date from YYYY-MM-DD to "Nov 12, 2025"
function formatEventDate(dateString: string): string {
	const date = new Date(dateString + "T00:00:00"); // Add time to avoid timezone issues
	return date.toLocaleDateString("en-US", {
		year: "numeric",
		month: "short",
		day: "numeric",
	});
}

// Social media links
const socialLinks = [
	{ name: "Resume", url: "/resume-shinji-pons.pdf" },
	{ name: "LinkedIn", url: "https://linkedin.com/in/shinjipons" },
	{ name: "Cal.com", url: "https://cal.com/shinjipons/" },
	{ name: "Twitter", url: "https://twitter.com/shinjipons" },
	{ name: "Figma", url: "https://www.figma.com/@shinjipons" },
];

// Work experience
const workExperience = [
	{
		company: "Formlabs",
		role: "Product designer",
		period: "2025 — 2026",
		url: "https://formlabs.com/",
	},
	{

						{githubStatsThisWeek.linesAdded.toLocaleString("en-US")}{" "}
						{githubStatsThisWeek.linesAdded === 1 ? "line" : "lines"} of code on{" "}
						<a href="https://github.com/shinjipons" target="_blank">
							GitHub

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "order": {
      "default": 0,
      "type": "number"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "url"
  ]
}
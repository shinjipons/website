{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "pubDate": {
      "type": "string",
      "format": "date-time"
    },
    "media": {
      "type": "string"
    },
    "mediaType": {
      "type": "string",
      "enum": [
        "image",
        "video"
      ]
    },
    "caption": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "pubDate",
    "media",
    "mediaType"
  ]
}